# Copy this file to .env and fill in your settings.

# OpenAI-compatible LLM. Works with OpenAI, OpenRouter, Anthropic via /v1
# proxies, Together, Groq, Ollama (`http://localhost:11434/v1`), llama.cpp
# (`--api`), vLLM, etc.
agent.api_key=
agent.llm_base_url=https://api.openai.com/v1
agent.model=gpt-4o-mini
agent.max_turns=25

# Command line of the stdio MCP server to spawn. Relative paths resolve
# against this executable's folder. By default we point at the bundled
# quickstart_stdio sample.
mcp.command=..\..\quickstart_stdio\bin\QuickStartStdio.exe
